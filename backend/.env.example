# Server
PORT=4000
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-string
CORS_ORIGIN=http://localhost:3000

# Database (SQLite file path)
DB_PATH=./data/keyone.db

# AI provider: groq | openai | none  (groq is free-tier friendly)
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Admin WhatsApp number (international format, no +). Hot-lead notifications go here.
# e.g. 9665XXXXXXXX
ADMIN_WHATSAPP=

# Anti-ban tuning
MIN_REPLY_DELAY_MS=1500
MAX_REPLY_DELAY_MS=6500
TYPING_CHARS_PER_SEC=18
MAX_MESSAGES_PER_MINUTE=12
